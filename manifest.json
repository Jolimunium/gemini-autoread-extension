{
  "manifest_version": 3,
  "name": "Gemini Auto-Read",
  "version": "1.0.0",
  "description": "Auto-play voice responses on Gemini",
  "permissions": ["storage"],
  "icons": {
    "16": "src/assets/icon.png",
    "48": "src/assets/icon.png",
    "128": "src/assets/icon.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/assets/kofi_button.svg", "src/assets/icon.png"],
      "matches": ["https://gemini.google.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://gemini.google.com/*"],
      "js": [
        "src/config.js",
        "src/utils.js",
        "src/styles/theme.js",
        "src/stateManager.js",
        "src/storageService.js",
        "src/components/FloatingToggle.js",
        "src/components/SyncModeSelector.js",
        "src/components/StartupConfig.js",
        "src/components/RetryInput.js",
        "src/components/DebounceInput.js",
        "src/components/DebugToggle.js",
        "src/components/ShortcutKeyBind.js",
        "src/uiBuilder.js",
        "src/observer.js",
        "src/shortcuts.js",
        "src/contentMain.js"
      ]
    }
  ],
  "action": {
    "default_icon": {
      "16": "src/assets/icon.png",
      "48": "src/assets/icon.png",
      "128": "src/assets/icon.png"
    }
  }
}
